RewriteEngine On

# --- Robots nuisibles : scrapers SEO commerciaux + crawlers agressifs ---
# UA honnêtes uniquement. Ne touche NI aux moteurs (Google/Bing/Qwant) NI aux
# IA autorisées dans robots.txt (GPTBot, ClaudeBot, Perplexity, Google-Extended).
RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|MJ12bot|DotBot|BLEXBot|DataForSeoBot|Barkrowler|Bytespider) [NC]
RewriteRule .* - [F,L]

# --- Sondes de failles : site 100% statique, aucun PHP ni WordPress ---
RewriteRule \.php$ - [F,L]
RewriteRule (^|/)(wp-login|wp-admin|xmlrpc|wp-content|wp-includes) - [F,L]

# Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Cache statique
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/html "access plus 1 hour"
ExpiresByType text/css "access plus 1 month"
ExpiresByType application/javascript "access plus 1 month"
ExpiresByType image/png "access plus 1 month"
ExpiresByType image/svg+xml "access plus 1 month"
ExpiresByType font/woff2 "access plus 1 year"
ExpiresByType application/json "access plus 1 day"
</IfModule>

# Service Worker : cache très court (5 min) — le SW doit être refetché souvent
# pour que les updates prennent effet rapidement côté utilisateur.
<IfModule mod_headers.c>
<FilesMatch "^sw\.js$">
Header set Cache-Control "max-age=300, must-revalidate"
</FilesMatch>
<FilesMatch "^manifest\.json$">
Header set Cache-Control "max-age=3600"
</FilesMatch>
</IfModule>

# Sécurité
<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "DENY"
Header set Referrer-Policy "no-referrer"
Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
Header set Permissions-Policy "camera=(self), microphone=(), geolocation=()"
Header set Cross-Origin-Opener-Policy "same-origin"
# wasm-unsafe-eval requis pour Tesseract.js, blob: pour les workers locaux
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
</IfModule>

# Compression (Performance Sentinel)
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_brotli.c>
AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# Fichier par défaut
DirectoryIndex index.html
